PORT=5000
NODE_ENV=development

MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/earnersmatter?retryWrites=true&w=majority

JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

APP_URL=http://localhost:3000
UPLOAD_DIR=uploads

# Cloudinary — for image uploads (optional, falls back to local disk if not set)
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# Reseed protection — required to use the database reset endpoint
# Generate a strong random key (e.g., openssl rand -hex 32)
RESEED_KEY=change-this-to-a-random-secret-key
